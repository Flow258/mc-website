# ============================================================
# ENVIRONMENT VARIABLES — copy to .env.local and fill in
# ============================================================

# ── Database (Neon.tech free tier) ──────────────────────────
# Get from: https://neon.tech → New Project → Connection string
DATABASE_URL="postgresql://neondb_owner:npg_5cB1uPpLZsJE@ep-red-sunset-ao4vj0yp-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ── NextAuth ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# ── Discord OAuth ────────────────────────────────────────────
# Get from: https://discord.com/developers/applications
# → New Application → OAuth2 → Client ID / Client Secret
# Redirect URI to add: https://your-domain/api/auth/callback/discord
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"

# ── Minecraft Server ─────────────────────────────────────────
MC_SERVER_HOST="play.yourserver.net"
MC_SERVER_PORT="25565"

# ── Public vars (visible in browser) ─────────────────────────
NEXT_PUBLIC_MC_HOST="play.yourserver.net"

# ── Plugin secret (shared with your Minecraft plugin) ────────
# Used to authenticate /api/link PUT requests from your plugin
# Generate with: openssl rand -hex 32
PLUGIN_SECRET="replace-with-another-long-random-string"
